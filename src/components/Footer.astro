---
import { SITE_TITLE } from '../consts';
const today = new Date();
---
<footer>
  <div class="footer-container">
    <div class="footer-content">
      <div class="footer-brand">
        <div class="brand-logo">
          <span class="brand-icon">🌱</span>
          <span class="brand-name">{SITE_TITLE}</span>
        </div>
        <p class="brand-tagline">Practical SEO guides for small business owners.</p>
      </div>
      <div class="footer-links">
        <div class="footer-column">
          <h4>Resources</h4>
          <ul>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/newsletter">Newsletter</a></li>
            <li><a href="/free-checklist">Free SEO Checklist</a></li>
            <li><a href="#coming-soon">Templates <span class="coming-soon-label">(Coming Soon)</span></a></li>
            <li><a href="#coming-soon">Courses <span class="coming-soon-label">(Coming Soon)</span></a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/consultation">Book a Call</a></li>
            <li><a href="mailto:hello@yourfriendlyseo.com">Contact</a></li>
            <li><a href="/privacy-policy">Privacy Policy</a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h4>Connect</h4>
          <ul>
            <li><a href="mailto:hello@yourfriendlyseo.com">Email Emil</a></li>
            <li><a href="https://www.linkedin.com/in/emil-mequita/" target="_blank" rel="noopener">LinkedIn</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background-color: var(--color-primary);
    color: var(--color-gray-300);
    padding: var(--space-16) var(--space-4) var(--space-8);
    margin-top: var(--space-20);
  }

  .footer-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Brand */
  .footer-brand {
    max-width: 300px;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .brand-icon {
    font-size: var(--font-size-2xl);
  }

  .brand-name {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-white);
  }

  .brand-tagline {
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-gray-400);
    margin: 0;
  }

  /* Footer Links */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .footer-column h4 {
    color: var(--color-white);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-column li {
    margin-bottom: var(--space-3);
  }

  .footer-column a {
    color: var(--color-gray-400);
    text-decoration: none;
    font-size: var(--font-size-base);
    transition: color 0.2s ease;
  }

  .footer-column a:hover {
    color: var(--color-accent-light);
    text-decoration: none;
  }

  .coming-soon-label {
    font-size: 0.75em;
    color: var(--color-gray-500);
    font-style: italic;
  }

  /* Footer Bottom */
  .footer-bottom {
    text-align: center;
    padding-top: var(--space-8);
  }

  .footer-bottom p {
    font-size: var(--font-size-sm);
    color: var(--color-gray-500);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .footer-brand {
      max-width: 100%;
    }
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    footer {
      padding: var(--space-12) var(--space-4) var(--space-6);
      margin-top: var(--space-12);
    }
    .footer-links {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .footer-content {
      padding-bottom: var(--space-8);
      margin-bottom: var(--space-8);
    }
  }
</style>
