---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = "Free DIY SEO Tools | yourfriendlyseo.com";
const description = "Free SEO tools built for in-house teams and solo operators. Redirect mappers, internal link finders, and more — no login required.";
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead title={title} description={description} />
</head>
<body>
  <Header />

  <section class="hero-resources">
    <div class="hero-inner">
      <div class="hero-eyebrow">Free Tools</div>
      <h1>DIY SEO Tools</h1>
      <p class="hero-sub">Simple, no-login tools built for SEOs who'd rather do the work than pay for bloated platforms. Use them, bookmark them, share them.</p>
    </div>
  </section>

  <section class="tools-section">
    <div class="container">
      <div class="tools-grid">

        <div class="tool-card">
          <div class="tool-meta">
            <span class="tool-badge free">Free</span>
          </div>
          <div class="tool-icon">🔀</div>
          <h2>Redirect Mapper</h2>
          <p>Automatically match old URLs to new URLs using a weighted similarity algorithm — URL structure, page title, and keyword overlap. Export your redirect map as a CSV in seconds.</p>
          <ul class="tool-features">
            <li>Weighted Jaccard similarity scoring</li>
            <li>Confidence ratings (High / Medium / Low)</li>
            <li>CSV export for your dev team</li>
            <li>Works with any CMS or platform</li>
          </ul>
          <a href="/products/redirect-mapper" class="btn-tool">Open Redirect Mapper →</a>
        </div>

        <div class="tool-card">
          <div class="tool-meta">
            <span class="tool-badge free">Free</span>
          </div>
          <div class="tool-icon">🔗</div>
          <h2>Internal Link Recommender</h2>
          <p>Find internal linking opportunities by scoring your existing pages against target keywords and URLs. Get anchor text suggestions and a CSV ready to hand off to your content team.</p>
          <ul class="tool-features">
            <li>Token overlap relevance scoring</li>
            <li>Suggested anchor text for each link</li>
            <li>Paste your URL list — no crawling needed</li>
            <li>CSV export with all recommendations</li>
          </ul>
          <a href="/products/internal-link-recommender" class="btn-tool">Open Link Recommender →</a>
        </div>

        <div class="tool-card tool-card-paid">
          <div class="tool-meta">
            <span class="tool-badge paid">$97 · Paid</span>
          </div>
          <div class="tool-icon">🚀</div>
          <h2>Website Migration Toolkit</h2>
          <p>A complete system for planning and executing SEO-safe website migrations. Pre-migration audit checklist, URL inventory template, redirect map guide, launch runbook, and a post-launch monitoring dashboard — plus a 30-minute strategy call.</p>
          <ul class="tool-features">
            <li>50-point pre-migration audit checklist</li>
            <li>URL inventory & priority scoring template</li>
            <li>Launch day runbook with rollback plan</li>
            <li>Post-launch Looker Studio dashboard</li>
            <li>30-min migration review call with Emil</li>
          </ul>
          <a href="/products/migration-toolkit" class="btn-tool btn-tool-paid">Learn More →</a>
        </div>

      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <h2>Have a specific SEO problem?</h2>
        <p>These tools handle the automatable stuff. For anything more complex — migrations, audits, strategy — book a call and let's talk through it together.</p>
        <a href="/consultation" class="btn-cta">Book a Free Intro Call →</a>
      </div>
    </div>
  </section>

  <Footer />
</body>
</html>

<style>
  /* Hero */
  .hero-resources {
    background: linear-gradient(135deg, #0F172A 0%, #1E3A5F 60%, #0D9488 100%);
    padding: var(--space-16) var(--space-4) var(--space-14);
    text-align: center;
  }
  .hero-inner { max-width: 680px; margin: 0 auto; }
  .hero-eyebrow {
    display: inline-block;
    font-size: var(--font-size-sm); font-weight: var(--font-weight-semibold);
    color: #5EEAD4; text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
  }
  .hero-resources h1 {
    font-size: clamp(2.4rem, 6vw, 3.5rem);
    color: #fff; margin-bottom: var(--space-5); line-height: 1.1;
  }
  .hero-sub {
    font-size: var(--font-size-lg); color: rgba(255,255,255,0.8);
    line-height: 1.65; max-width: 560px; margin: 0 auto;
  }

  /* Container */
  .container { max-width: 1100px; margin: 0 auto; }

  /* Tools grid */
  .tools-section { padding: var(--space-16) var(--space-4); background: var(--color-gray-50); }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .tool-card {
    background: #fff;
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    display: flex; flex-direction: column;
    transition: box-shadow 0.2s;
  }
  .tool-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }
  .tool-card-paid {
    border-color: #7C3AED;
    background: #FDFCFF;
  }

  .tool-meta { margin-bottom: var(--space-4); }
  .tool-badge {
    display: inline-block;
    font-size: var(--font-size-xs); font-weight: var(--font-weight-bold);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .tool-badge.free { background: #D1FAE5; color: #065F46; }
  .tool-badge.paid { background: #EDE9FE; color: #5B21B6; }

  .tool-icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
  .tool-card h2 {
    font-size: var(--font-size-2xl); color: var(--color-primary);
    margin-bottom: var(--space-3);
  }
  .tool-card > p {
    color: var(--color-gray-600); line-height: 1.65;
    margin-bottom: var(--space-5); flex-grow: 0;
  }

  .tool-features {
    list-style: none; padding: 0; margin: 0 0 var(--space-6);
    flex-grow: 1;
  }
  .tool-features li {
    font-size: var(--font-size-sm); color: var(--color-gray-600);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-gray-100);
    display: flex; align-items: flex-start; gap: var(--space-2);
  }
  .tool-features li:last-child { border-bottom: none; }
  .tool-features li::before {
    content: '✓';
    color: #059669; font-weight: bold; flex-shrink: 0;
  }

  .btn-tool {
    display: block; text-align: center;
    padding: var(--space-4) var(--space-6);
    background: var(--color-primary); color: #fff;
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-base);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: auto;
  }
  .btn-tool:hover { opacity: 0.85; text-decoration: none; }
  .btn-tool-paid { background: #7C3AED; }

  /* Bottom CTA */
  .cta-section { padding: var(--space-16) var(--space-4); background: #fff; }
  .cta-inner {
    max-width: 600px; margin: 0 auto;
    text-align: center;
  }
  .cta-inner h2 { font-size: var(--font-size-3xl); color: var(--color-primary); margin-bottom: var(--space-4); }
  .cta-inner p { color: var(--color-gray-600); line-height: 1.65; margin-bottom: var(--space-8); }
  .btn-cta {
    display: inline-block;
    padding: var(--space-4) var(--space-8);
    background: var(--color-accent); color: #000;
    font-weight: var(--font-weight-bold); font-size: var(--font-size-lg);
    border-radius: var(--radius-xl); text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn-cta:hover { opacity: 0.9; text-decoration: none; }
</style>
