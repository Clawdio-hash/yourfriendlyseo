---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BeehiivEmbed from '../../components/BeehiivEmbed.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pageTitle = 'Blog | Your Friendly SEO';
const pageDescription = 'Practical SEO guides for small business owners';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Page Header -->
			<section class="page-header">
				<div class="container">
					<h1 class="page-title">Blog</h1>
					<p class="page-description">Practical SEO guides for small business owners</p>
				</div>
			</section>

			<!-- Blog Posts Grid -->
			<section class="blog-posts">
				<div class="container">
					<div class="posts-grid">
						{posts.map((post) => {
							const slug = post.id.replace(/\.mdx?$/, '');
							return (
								<article class="post-card">
									<div class="post-card-content">
										<time class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</time>
										<h2 class="post-title">
											<a href={`/blog/${slug}/`}>{post.data.title}</a>
										</h2>
										<p class="post-description">{post.data.description}</p>
										<div class="post-tags">
											{post.data.tags?.slice(0, 3).map((tag: string) => (
												<span class="tag">{tag}</span>
											))}
										</div>
										<a href={`/blog/${slug}/`} class="post-link">
											Read Guide →
										</a>
									</div>
								</article>
							);
						})}
					</div>
				</div>
			</section>

			<!-- Newsletter Section -->
			<section class="newsletter-section">
				<div class="container">
					<BeehiivEmbed 
						title="📥 Get Weekly SEO Tips That Actually Work" 
						description="Join 1,000+ small business owners getting actionable SEO strategies and free resources delivered to their inbox every week. No fluff, just results."
					/>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 100%;
	}

	.container {
		max-width: var(--container-xl);
		margin: 0 auto;
		padding: 0 var(--space-4);
	}

	/* Page Header */
	.page-header {
		padding: var(--space-16) var(--space-4) var(--space-12);
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	.page-header::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image: 
			radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.05) 0%, transparent 50%),
			radial-gradient(circle at 80% 50%, rgba(245, 158, 11, 0.1) 0%, transparent 50%);
		pointer-events: none;
	}

	.page-title {
		font-size: var(--font-size-5xl);
		font-weight: var(--font-weight-bold);
		color: var(--color-white);
		margin: 0 0 var(--space-4) 0;
		letter-spacing: -0.03em;
		text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
		position: relative;
		z-index: 1;
	}

	.page-description {
		font-size: var(--font-size-xl);
		color: var(--color-gray-200);
		margin: 0;
		position: relative;
		z-index: 1;
	}

	/* Blog Posts Grid */
	.blog-posts {
		padding: var(--space-20) var(--space-4);
		background-color: var(--color-white);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-8);
	}

	.post-card {
		background-color: var(--color-white);
		border: 2px solid var(--color-gray-200);
		border-radius: var(--radius-xl);
		padding: var(--space-8);
		transition: all 0.3s ease;
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.post-card:hover {
		border-color: var(--color-accent);
		box-shadow: var(--shadow-xl);
		transform: translateY(-4px);
	}

	.post-card-content {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.post-date {
		display: inline-block;
		font-size: var(--font-size-sm);
		color: var(--color-gray-500);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: var(--space-4);
	}

	.post-title {
		font-size: var(--font-size-2xl);
		margin: 0 0 var(--space-4) 0;
		line-height: var(--line-height-tight);
	}

	.post-title a {
		color: var(--color-primary);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.post-title a:hover {
		color: var(--color-accent-dark);
	}

	.post-description {
		color: var(--color-gray-600);
		line-height: var(--line-height-relaxed);
		margin: 0 0 var(--space-6) 0;
		flex-grow: 1;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin-bottom: var(--space-6);
	}

	.tag {
		display: inline-block;
		padding: var(--space-1) var(--space-3);
		background-color: var(--color-gray-100);
		color: var(--color-gray-700);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		border-radius: var(--radius-full);
	}

	.post-link {
		color: var(--color-accent-dark);
		font-weight: var(--font-weight-semibold);
		text-decoration: none;
		transition: all 0.2s ease;
		display: inline-flex;
		align-items: center;
		margin-top: auto;
	}

	.post-link:hover {
		color: var(--color-accent);
		gap: var(--space-2);
	}

	/* Newsletter Section */
	.newsletter-section {
		padding: var(--space-20) var(--space-4);
		background-color: var(--color-gray-50);
	}

	/* Responsive */
	@media (max-width: 968px) {
		.posts-grid {
			grid-template-columns: 1fr;
			gap: var(--space-6);
		}

		.page-title {
			font-size: var(--font-size-4xl);
		}

		.page-description {
			font-size: var(--font-size-lg);
		}
	}

	@media (max-width: 640px) {
		.page-header {
			padding: var(--space-12) var(--space-4) var(--space-8);
		}

		.page-title {
			font-size: var(--font-size-3xl);
		}

		.blog-posts,
		.newsletter-section {
			padding: var(--space-12) var(--space-4);
		}

		.post-card {
			padding: var(--space-6);
		}

		.post-title {
			font-size: var(--font-size-xl);
		}
	}
</style>
