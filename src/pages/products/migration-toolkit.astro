---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const stripeLink = "https://buy.stripe.com/3cI6oG4IWbEF83JbbK8ww04";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Website Migration Toolkit | YourFriendlySEO"
      description="The complete DIY toolkit for planning and executing a website migration without losing organic traffic. 50-point checklist, launch day runbook, and more."
    />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero-tool">
        <div class="container">
          <div class="tool-badge">Website Migration Toolkit</div>
          <h1>Migrate Your Site Without Losing Your Rankings</h1>
          <p class="hero-sub">
            The complete system used in enterprise migrations — checklists, runbooks, and templates
            so you don't have to figure it out under pressure on launch day.
          </p>
          <div class="hero-price">
            <span class="price-amount">$97</span>
            <span class="price-note">one-time · instant access</span>
          </div>
          <a href={stripeLink} class="btn-primary-tool">Buy Now — $97</a>
          <p class="hero-reassurance">Instant access after checkout. No subscription.</p>
        </div>
      </section>

      <!-- What's Inside -->
      <section class="section-light">
        <div class="container">
          <h2>Everything You Need to Migrate With Confidence</h2>
          <p class="section-intro">
            Built from real enterprise migrations. Every item in this toolkit represents a failure
            mode we've seen firsthand — and documented so you don't have to learn it the hard way.
          </p>
          <div class="toolkit-grid">
            <div class="toolkit-card">
              <div class="toolkit-icon">✅</div>
              <h3>Pre-Migration Audit Checklist</h3>
              <p>50 checkpoints to validate before you move a single URL. Crawl state, top-performing pages, redirect inventory, backlink audit, Core Web Vitals baseline, and more — organized into 8 sections with clear guidance on what to look for and why.</p>
            </div>
            <div class="toolkit-card">
              <div class="toolkit-icon">📋</div>
              <h3>Launch Day Runbook</h3>
              <p>A battle-tested hour-by-hour playbook for migration day. Includes go/no-go decision criteria, team roles, escalation triggers, rollback procedures, and a post-launch monitoring checklist — so you're never improvising under pressure.</p>
            </div>
            <div class="toolkit-card">
              <div class="toolkit-icon">🗂️</div>
              <h3>URL Inventory & Redirect Map Template</h3>
              <p>A structured spreadsheet for cataloging every URL on your current site, mapping each to its new destination, and tracking redirect status. Never lose a page in the migration shuffle.</p>
            </div>
            <div class="toolkit-card">
              <div class="toolkit-icon">📊</div>
              <h3>Post-Launch Monitoring Dashboard</h3>
              <p>A Looker Studio template pre-wired for tracking the KPIs that matter most in the 30 days after go-live: crawl errors, index coverage, organic clicks, Core Web Vitals, and 404 spikes.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Who It's For -->
      <section class="section-dark">
        <div class="container">
          <h2>Who This Is For</h2>
          <div class="for-grid">
            <div class="for-item">
              <span class="for-check">✓</span>
              <p>Business owners planning a site redesign or platform move who want to protect their organic traffic</p>
            </div>
            <div class="for-item">
              <span class="for-check">✓</span>
              <p>In-house SEOs who need structured documentation to align with dev and content teams</p>
            </div>
            <div class="for-item">
              <span class="for-check">✓</span>
              <p>Marketing managers who are being handed a migration project and need a proven framework fast</p>
            </div>
            <div class="for-item">
              <span class="for-check">✓</span>
              <p>Freelancers and consultants who want a professional, repeatable process they can charge for</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Pricing -->
      <section class="section-light">
        <div class="container pricing-container">
          <h2>Simple, One-Time Pricing</h2>
          <div class="pricing-card">
            <div class="pricing-label">Website Migration Toolkit</div>
            <div class="pricing-amount">$97</div>
            <div class="pricing-term">one-time payment · instant access</div>
            <ul class="pricing-list">
              <li>✅ Pre-Migration Audit Checklist (50 checkpoints)</li>
              <li>✅ Launch Day Runbook with rollback procedures</li>
              <li>✅ URL Inventory & Redirect Map template</li>
              <li>✅ Post-Launch Monitoring Dashboard</li>
              <li>✅ Lifetime access — yours to keep and reuse</li>
            </ul>
            <a href={stripeLink} class="btn-cta-large">Buy Now — $97</a>
            <p class="pricing-note">Delivered instantly via Google Drive. No subscription, no upsells.</p>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="section-faq">
        <div class="container">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            <div class="faq-item">
              <h3>When do I get access?</h3>
              <p>Instantly. After payment you're redirected straight to your access page with Google Drive links to every resource. No waiting, no email delay.</p>
            </div>
            <div class="faq-item">
              <h3>Is this different from the consultation?</h3>
              <p>Yes. The consultation is a 1-on-1 session where Emil reviews your specific site and migration plan. The toolkit is a set of templates and checklists you work through yourself. Many people use both — the toolkit to plan and execute, and the consultation to sanity-check before go-live.</p>
            </div>
            <div class="faq-item">
              <h3>What format are the resources in?</h3>
              <p>The checklist and runbook are printable PDFs. The URL inventory template is a Google Sheet you can copy to your own Drive. The monitoring dashboard is a Looker Studio template you connect to your own GA4 property.</p>
            </div>
            <div class="faq-item">
              <h3>Will this work for my platform?</h3>
              <p>Yes. The toolkit is platform-agnostic — it works whether you're moving from WordPress to Webflow, Shopify to a custom build, or any other CMS combination. The principles apply regardless of platform.</p>
            </div>
            <div class="faq-item">
              <h3>What if I have questions after purchasing?</h3>
              <p>You can email hello@yourfriendlyseo.com with any questions about the toolkit. For hands-on help with your specific migration, the consultation is the right next step.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Bottom CTA -->
      <section class="section-cta-bottom">
        <div class="container">
          <h2>Stop Guessing. Start With a System.</h2>
          <p>Every migration failure we've seen came down to skipped steps and missing documentation. The toolkit fixes that before launch day.</p>
          <a href={stripeLink} class="btn-primary-tool">Get the Toolkit — $97</a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .hero-tool {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    padding: 5rem 0 4rem;
    text-align: center;
  }
  .tool-badge {
    display: inline-block;
    background: #f59e0b;
    color: #0f172a;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.35rem 1rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .hero-tool h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    max-width: 750px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-sub {
    font-size: 1.15rem;
    color: #cbd5e1;
    max-width: 580px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }
  .hero-price { margin-bottom: 1.5rem; }
  .price-amount {
    font-size: 2.5rem;
    font-weight: 800;
    color: #f59e0b;
  }
  .price-note {
    display: block;
    font-size: 0.9rem;
    color: #94a3b8;
    margin-top: 0.25rem;
  }
  .btn-primary-tool {
    display: inline-block;
    background: #f59e0b;
    color: #0f172a;
    font-weight: 700;
    font-size: 1.1rem;
    padding: 0.9rem 2.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary-tool:hover { background: #d97706; transform: translateY(-1px); }
  .hero-reassurance { margin-top: 1rem; font-size: 0.85rem; color: #64748b; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 1.5rem; }
  .section-light { padding: 4.5rem 0; background: #f8fafc; }
  .section-dark { padding: 4.5rem 0; background: #0f172a; color: white; }
  .section-dark h2 { color: white; }
  .section-faq { padding: 4.5rem 0; background: white; }
  .section-cta-bottom { padding: 5rem 0; background: #0f172a; color: white; text-align: center; }
  .section-cta-bottom h2 { color: white; font-size: clamp(1.5rem, 3.5vw, 2.25rem); margin-bottom: 1rem; }
  .section-cta-bottom p { color: #94a3b8; margin-bottom: 2rem; max-width: 520px; margin-left: auto; margin-right: auto; }
  h2 { font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 800; color: #0f172a; margin-bottom: 1rem; }
  .section-intro { color: #475569; font-size: 1.05rem; max-width: 640px; margin-bottom: 2.5rem; line-height: 1.65; }
  .toolkit-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 1.5rem; }
  .toolkit-card { background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.75rem; }
  .toolkit-icon { font-size: 1.75rem; margin-bottom: 0.75rem; }
  .toolkit-card h3 { font-size: 1.1rem; font-weight: 700; color: #0f172a; margin-bottom: 0.5rem; }
  .toolkit-card p { color: #475569; font-size: 0.95rem; line-height: 1.6; }
  .for-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 1.25rem; margin-top: 1.5rem; }
  .for-item { display: flex; gap: 0.75rem; align-items: flex-start; }
  .for-check { color: #f59e0b; font-weight: 700; font-size: 1.1rem; flex-shrink: 0; }
  .for-item p { color: #cbd5e1; line-height: 1.55; margin: 0; }
  .pricing-container { text-align: center; }
  .pricing-card { background: white; border: 2px solid #0f172a; border-radius: 16px; padding: 2.5rem; max-width: 500px; margin: 2rem auto 0; }
  .pricing-label { font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #64748b; margin-bottom: 1rem; }
  .pricing-amount { font-size: 3.5rem; font-weight: 800; color: #0f172a; line-height: 1; }
  .pricing-term { font-size: 0.85rem; color: #64748b; margin: 0.5rem 0 1.5rem; }
  .pricing-list { list-style: none; padding: 0; margin: 0 0 2rem; text-align: left; }
  .pricing-list li { padding: 0.5rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.95rem; color: #334155; }
  .btn-cta-large { display: inline-block; background: #f59e0b; color: #0f172a; font-weight: 700; font-size: 1.15rem; padding: 1rem 3rem; border-radius: 8px; text-decoration: none; transition: background 0.2s, transform 0.15s; width: 100%; box-sizing: border-box; text-align: center; }
  .btn-cta-large:hover { background: #d97706; transform: translateY(-1px); }
  .pricing-note { margin-top: 1rem; font-size: 0.8rem; color: #94a3b8; }
  .faq-list { max-width: 680px; margin: 2rem auto 0; }
  .faq-item { border-bottom: 1px solid #e2e8f0; padding: 1.5rem 0; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: #0f172a; margin-bottom: 0.5rem; }
  .faq-item p { color: #475569; line-height: 1.65; margin: 0; font-size: 0.95rem; }
</style>
