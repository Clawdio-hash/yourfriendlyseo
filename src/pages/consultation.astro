---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = "Book a 1-on-1 SEO Strategy Session with Emil";
const pageDescription = "Get a personalized SEO audit, keyword strategy, content roadmap, and 30-day action plan in a 60-minute session with Emil.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${pageTitle} | ${SITE_TITLE}`} description={pageDescription} />
	</head>
	<body>
		<Header />
		
		<main class="consultation-page">
			<div class="container">
				<div class="consultation-content">
					<!-- Headline Section -->
					<section class="consultation-header">
						<div class="author-badge">
							<div class="author-image">👨‍💼</div>
							<div class="author-info">
								<p class="author-name">Emil Mequita</p>
								<p class="author-title">SEO Strategist & Consultant</p>
								<a href="https://www.linkedin.com/in/emil-mequita/" target="_blank" rel="noopener" class="author-linkedin">
									Connect on LinkedIn →
								</a>
							</div>
						</div>
						
						<h1 class="page-title">Book a 1-on-1 SEO Strategy Session with Emil</h1>
						<p class="page-subtitle">
							Get personalized guidance from an experienced SEO professional. Walk away with a clear roadmap to rank higher, attract more customers, and grow your business organically.
						</p>
					</section>
					
					<!-- What You Get Section -->
					<section class="consultation-details">
						<div class="details-grid">
							<div class="details-main">
								<h2>What You'll Get</h2>
								<div class="details-card">
									<div class="detail-icon">🔍</div>
									<div class="detail-content">
										<h3>Personalized SEO Audit</h3>
										<p>I'll review your website live during the call and identify the exact issues holding you back from ranking higher.</p>
									</div>
								</div>
								
								<div class="details-card">
									<div class="detail-icon">🎯</div>
									<div class="detail-content">
										<h3>Custom Keyword Strategy</h3>
										<p>Get a targeted list of keywords you should rank for — based on your niche, competition, and goals.</p>
									</div>
								</div>
								
								<div class="details-card">
									<div class="detail-icon">📝</div>
									<div class="detail-content">
										<h3>Content Roadmap</h3>
										<p>Receive a strategic content plan with topics that will attract your ideal customers and convert them into paying clients.</p>
									</div>
								</div>
								
								<div class="details-card">
									<div class="detail-icon">✅</div>
									<div class="detail-content">
										<h3>30-Day Action Plan</h3>
										<p>Leave with a prioritized list of exactly what to do in the next 30 days to see real improvements in your rankings.</p>
									</div>
								</div>
								
								<h2 style="margin-top: var(--space-12);">You'll Walk Away Knowing...</h2>
								<ul class="outcomes-list">
									<li>✓ Exactly what's holding your site back from ranking higher</li>
									<li>✓ A prioritized list of actions that will move the needle (no more guessing)</li>
									<li>✓ How AI is changing SEO and how to adapt your strategy</li>
									<li>✓ Which keywords you should target (and which ones to avoid)</li>
									<li>✓ How to create content that ranks AND converts</li>
									<li>✓ Technical SEO fixes you can implement immediately</li>
									<li>✓ A realistic timeline for when you can expect to see results</li>
								</ul>
							</div>
							
							<!-- Booking Card -->
							<div class="booking-card">
								<div class="booking-card-content">
									<div class="booking-header">
										<h3>60-Minute Strategy Session</h3>
										<div class="booking-price">
											<span class="price-amount">$197</span>
											<span class="price-label">One-time payment</span>
										</div>
									</div>
									
									<div class="booking-includes">
										<h4>Includes:</h4>
										<ul>
											<li>✓ Live website audit</li>
											<li>✓ Keyword strategy</li>
											<li>✓ Content roadmap</li>
											<li>✓ 30-day action plan</li>
											<li>✓ Q&A time for your questions</li>
											<li>✓ Recording of the session</li>
										</ul>
									</div>
									
									<a href="https://buy.stripe.com/28E6oGfnAaAB2Jpgw48ww00" class="btn btn-primary btn-large btn-full">
										Book Your Session Now
									</a>
									
									<p class="booking-note">
										After payment, you'll be redirected to schedule your session at a time that works for you.
									</p>
									
									<div class="booking-guarantee">
										<p><strong>100% Satisfaction Guarantee</strong></p>
										<p>If you don't find the session valuable, I'll refund your money. No questions asked.</p>
									</div>
								</div>
							</div>
						</div>
					</section>
					
					<!-- Who This Is For Section -->
					<section class="consultation-for">
						<h2>Is This Session Right for You?</h2>
						<div class="for-grid">
							<div class="for-card for-yes">
								<h3>✓ Perfect if you...</h3>
								<ul>
									<li>Own a small business and want to attract more customers organically</li>
									<li>Have tried SEO but aren't seeing results</li>
									<li>Want to stop paying thousands for SEO agencies</li>
									<li>Need a clear roadmap (not just generic advice)</li>
									<li>Are ready to put in the work to see results</li>
									<li>Want to understand AI's impact on SEO</li>
								</ul>
							</div>
							
							<div class="for-card for-no">
								<h3>✗ Not a fit if you...</h3>
								<ul>
									<li>Expect overnight results (SEO takes 3-6 months)</li>
									<li>Want me to do the work for you (this is strategic consulting)</li>
									<li>Aren't willing to invest time in your SEO</li>
									<li>Have a brand new website (less than 3 months old)</li>
								</ul>
							</div>
						</div>
					</section>
					
					<!-- FAQ Section -->
					<section class="consultation-faq">
						<h2>Frequently Asked Questions</h2>
						
						<div class="faq-item">
							<h3>How does scheduling work?</h3>
							<p>After you complete payment, you'll be redirected to a scheduling page where you can pick a time that works for you. Sessions are available Monday-Friday, 9am-5pm PST.</p>
						</div>
						
						<div class="faq-item">
							<h3>Do I need to prepare anything?</h3>
							<p>Just have your website URL ready and any specific questions you want answered. I'll do the rest.</p>
						</div>
						
						<div class="faq-item">
							<h3>Will I get a recording?</h3>
							<p>Yes! You'll receive a recording of the session so you can review the recommendations anytime.</p>
						</div>
						
						<div class="faq-item">
							<h3>What if I need ongoing support after the session?</h3>
							<p>I offer retainer packages for clients who need ongoing SEO guidance. We can discuss options during the call.</p>
						</div>
						
						<div class="faq-item">
							<h3>Can I get a refund?</h3>
							<p>Absolutely. If you don't find the session valuable, let me know within 7 days and I'll issue a full refund.</p>
						</div>
					</section>
					
					<!-- Final CTA -->
					<section class="consultation-cta-final">
						<div class="cta-final-content">
							<h2>Ready to Get Clarity on Your SEO Strategy?</h2>
							<p>Book your 60-minute session now and walk away with a clear action plan.</p>
							<a href="https://buy.stripe.com/28E6oGfnAaAB2Jpgw48ww00" class="btn btn-accent btn-large">
								Book Your Session - $197
							</a>
							<p class="cta-subtext">Limited slots available each week</p>
						</div>
					</section>
				</div>
			</div>
		</main>
		
		<Footer />
	</body>
</html>

<style>
	.consultation-page {
		background-color: var(--color-white);
	}
	
	.consultation-content {
		max-width: var(--container-lg);
		margin: 0 auto;
		padding: var(--space-12) var(--space-4) var(--space-20);
	}
	
	/* Header Section */
	.consultation-header {
		text-align: center;
		max-width: 800px;
		margin: 0 auto var(--space-16);
	}
	
	.author-badge {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-4);
		margin-bottom: var(--space-8);
		padding: var(--space-6);
		background-color: var(--color-gray-50);
		border-radius: var(--radius-xl);
		border: 2px solid var(--color-gray-200);
	}
	
	.author-image {
		font-size: 60px;
	}
	
	.author-info {
		text-align: left;
	}
	
	.author-name {
		font-size: var(--font-size-xl);
		font-weight: var(--font-weight-bold);
		color: var(--color-primary);
		margin: 0 0 var(--space-1);
	}
	
	.author-title {
		font-size: var(--font-size-base);
		color: var(--color-gray-600);
		margin: 0 0 var(--space-2);
	}
	
	.author-linkedin {
		font-size: var(--font-size-sm);
		color: var(--color-accent-dark);
		text-decoration: none;
		font-weight: var(--font-weight-semibold);
	}
	
	.author-linkedin:hover {
		color: var(--color-accent);
	}
	
	.page-title {
		font-size: var(--font-size-5xl);
		color: var(--color-primary);
		margin-bottom: var(--space-6);
	}
	
	.page-subtitle {
		font-size: var(--font-size-xl);
		color: var(--color-gray-600);
		line-height: var(--line-height-relaxed);
		margin: 0;
	}
	
	/* Details Grid */
	.details-grid {
		display: grid;
		grid-template-columns: 1fr 400px;
		gap: var(--space-12);
		align-items: start;
	}
	
	.details-main h2 {
		font-size: var(--font-size-3xl);
		color: var(--color-primary);
		margin-bottom: var(--space-8);
	}
	
	.details-card {
		display: flex;
		gap: var(--space-6);
		margin-bottom: var(--space-8);
	}
	
	.detail-icon {
		font-size: 40px;
		flex-shrink: 0;
	}
	
	.detail-content h3 {
		font-size: var(--font-size-xl);
		color: var(--color-primary);
		margin-bottom: var(--space-3);
	}
	
	.detail-content p {
		color: var(--color-gray-600);
		line-height: var(--line-height-relaxed);
		margin: 0;
	}
	
	.outcomes-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	
	.outcomes-list li {
		font-size: var(--font-size-lg);
		color: var(--color-gray-700);
		margin-bottom: var(--space-4);
		padding-left: 0;
		line-height: var(--line-height-relaxed);
	}
	
	/* Booking Card */
	.booking-card {
		position: sticky;
		top: calc(var(--space-20) + 20px);
	}
	
	.booking-card-content {
		background-color: var(--color-white);
		border: 3px solid var(--color-accent);
		border-radius: var(--radius-xl);
		padding: var(--space-8);
		box-shadow: var(--shadow-2xl);
	}
	
	.booking-header {
		text-align: center;
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-6);
		border-bottom: 2px solid var(--color-gray-200);
	}
	
	.booking-header h3 {
		font-size: var(--font-size-2xl);
		color: var(--color-primary);
		margin-bottom: var(--space-4);
	}
	
	.booking-price {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	
	.price-amount {
		font-size: var(--font-size-5xl);
		font-weight: var(--font-weight-bold);
		color: var(--color-accent-dark);
	}
	
	.price-label {
		font-size: var(--font-size-sm);
		color: var(--color-gray-500);
	}
	
	.booking-includes {
		margin-bottom: var(--space-8);
	}
	
	.booking-includes h4 {
		font-size: var(--font-size-lg);
		color: var(--color-primary);
		margin-bottom: var(--space-4);
	}
	
	.booking-includes ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	
	.booking-includes li {
		font-size: var(--font-size-base);
		color: var(--color-gray-700);
		margin-bottom: var(--space-3);
		padding-left: 0;
	}
	
	.booking-note {
		text-align: center;
		font-size: var(--font-size-sm);
		color: var(--color-gray-500);
		margin-top: var(--space-4);
		margin-bottom: var(--space-6);
	}
	
	.booking-guarantee {
		background-color: var(--color-gray-50);
		padding: var(--space-6);
		border-radius: var(--radius-lg);
		text-align: center;
	}
	
	.booking-guarantee p {
		font-size: var(--font-size-sm);
		color: var(--color-gray-700);
		margin: 0 0 var(--space-2);
	}
	
	.booking-guarantee p:last-child {
		margin-bottom: 0;
	}
	
	/* Who This Is For */
	.consultation-for {
		margin-top: var(--space-20);
		max-width: var(--container-md);
		margin-left: auto;
		margin-right: auto;
	}
	
	.consultation-for h2 {
		font-size: var(--font-size-3xl);
		color: var(--color-primary);
		text-align: center;
		margin-bottom: var(--space-12);
	}
	
	.for-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--space-8);
	}
	
	.for-card {
		padding: var(--space-8);
		border-radius: var(--radius-xl);
		border: 2px solid;
	}
	
	.for-yes {
		background-color: rgba(16, 185, 129, 0.05);
		border-color: var(--color-success);
	}
	
	.for-no {
		background-color: rgba(239, 68, 68, 0.05);
		border-color: var(--color-error);
	}
	
	.for-card h3 {
		font-size: var(--font-size-xl);
		margin-bottom: var(--space-6);
	}
	
	.for-yes h3 {
		color: var(--color-success);
	}
	
	.for-no h3 {
		color: var(--color-error);
	}
	
	.for-card ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	
	.for-card li {
		font-size: var(--font-size-base);
		color: var(--color-gray-700);
		margin-bottom: var(--space-3);
		padding-left: 0;
		line-height: var(--line-height-relaxed);
	}
	
	/* FAQ Section */
	.consultation-faq {
		margin-top: var(--space-20);
		max-width: var(--container-md);
		margin-left: auto;
		margin-right: auto;
	}
	
	.consultation-faq h2 {
		font-size: var(--font-size-3xl);
		color: var(--color-primary);
		text-align: center;
		margin-bottom: var(--space-12);
	}
	
	.faq-item {
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--color-gray-200);
	}
	
	.faq-item:last-child {
		border-bottom: none;
	}
	
	.faq-item h3 {
		font-size: var(--font-size-xl);
		color: var(--color-primary);
		margin-bottom: var(--space-4);
	}
	
	.faq-item p {
		font-size: var(--font-size-lg);
		color: var(--color-gray-600);
		line-height: var(--line-height-relaxed);
		margin: 0;
	}
	
	/* Final CTA */
	.consultation-cta-final {
		margin-top: var(--space-20);
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
		padding: var(--space-16);
		border-radius: var(--radius-2xl);
		text-align: center;
	}
	
	.cta-final-content h2 {
		font-size: var(--font-size-4xl);
		color: var(--color-white);
		margin-bottom: var(--space-4);
	}
	
	.cta-final-content p {
		font-size: var(--font-size-xl);
		color: var(--color-gray-200);
		margin-bottom: var(--space-8);
	}
	
	.cta-subtext {
		font-size: var(--font-size-sm);
		color: var(--color-gray-400);
		margin-top: var(--space-4);
	}
	
	/* Responsive */
	@media (max-width: 968px) {
		.details-grid,
		.for-grid {
			grid-template-columns: 1fr;
		}
		
		.booking-card {
			position: static;
		}
		
		.page-title {
			font-size: var(--font-size-3xl);
		}
		
		.author-badge {
			flex-direction: column;
			text-align: center;
		}
		
		.author-info {
			text-align: center;
		}
	}
	
	@media (max-width: 640px) {
		.page-title {
			font-size: var(--font-size-2xl);
		}
		
		.consultation-header,
		.consultation-for,
		.consultation-faq {
			margin-top: var(--space-12);
		}
	}
</style>
