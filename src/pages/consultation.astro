---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Book a 1-on-1 SEO Strategy Session with Emil | YourFriendlySEO">
<main class="consultation-page">

  <section class="hero">
    <div class="container">
      <h1>Book a 1-on-1 SEO Strategy Session with Emil</h1>
      <p class="subtitle">Get personalized guidance from someone who's been doing this for 10+ years</p>
      <a href="#booking" class="hero-cta">Book Your Session — $197 ↓</a>
    </div>
  </section>

  <section class="content">
    <div class="container">
      <div class="two-column">

        <div class="left-column">
          <div class="author-card">
            <img src="https://roastbrief.us/wp-content/uploads/2025/04/0014_Emil.jpeg" alt="Emil Mequita - SEO Consultant" class="author-photo" />
            <div class="author-info">
              <h3>Emil Mequita</h3>
              <p>SEO Consultant | 10+ Years Experience</p>
              <a href="https://www.linkedin.com/in/emil-mequita/" target="_blank" rel="noopener" class="linkedin-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
                Connect on LinkedIn
              </a>
            </div>
          </div>

          <div class="what-you-get">
            <h2>What You Get</h2>
            <ul>
              <li>
                <span class="icon">🔍</span>
                <div>
                  <strong>Personalized SEO Audit</strong>
                  <p>Live review of your site's SEO health, technical issues, and quick wins</p>
                </div>
              </li>
              <li>
                <span class="icon">🎯</span>
                <div>
                  <strong>Custom Keyword Strategy</strong>
                  <p>Keywords tailored to your business, competition level, and goals</p>
                </div>
              </li>
              <li>
                <span class="icon">📋</span>
                <div>
                  <strong>30-Day Action Plan</strong>
                  <p>Prioritized list of exactly what to do first, second, and third</p>
                </div>
              </li>
              <li>
                <span class="icon">📝</span>
                <div>
                  <strong>Content Roadmap</strong>
                  <p>What to write, in what order, to maximize your organic traffic</p>
                </div>
              </li>
              <li>
                <span class="icon">🎥</span>
                <div>
                  <strong>Session Recording</strong>
                  <p>Full recording of our call so you can revisit it anytime</p>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <div class="right-column">
          <div class="booking-card" id="booking">
            <div class="price-tag">
              <span class="price">$197</span>
              <span class="duration">60 minutes</span>
            </div>
            <h2>Walk Away With Clarity</h2>
            <ul class="outcomes">
              <li>✓ Know exactly what's holding your site back</li>
              <li>✓ Get a prioritized action list that will move the needle</li>
              <li>✓ Understand how AI is changing SEO and how to adapt</li>
              <li>✓ Same strategies I use for enterprise brands — applied to your business</li>
            </ul>
            <a href="https://buy.stripe.com/dRm14mdfs9wxgAf0x68ww02" class="cta-button" id="checkout-button">
              Book Your Session — $197
            </a>
            <p class="guarantee">
              💬 Not sure if this is right for you? Reply to any of my emails and ask. No pressure.
            </p>
          </div>

          <div class="testimonial">
            <div class="quote-mark">"</div>
            <p class="quote-text">Emil helped me understand what I was doing wrong in just one call. Within a month, I was on page 1 for my main keyword.</p>
            <p class="attribution">— Happy Client</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>What happens after I pay?</h3>
          <p>You'll receive an email with a link to schedule your session at a time that works for both of us.</p>
        </div>
        <div class="faq-item">
          <h3>How do we meet?</h3>
          <p>We'll meet over Zoom. I'll send you the link before our session.</p>
        </div>
        <div class="faq-item">
          <h3>What should I prepare?</h3>
          <p>Just have access to your website, Google Search Console, and Analytics. I'll guide you through everything else.</p>
        </div>
        <div class="faq-item">
          <h3>What if I need to reschedule?</h3>
          <p>No problem — just give me 24 hours notice and we'll find a new time.</p>
        </div>
      </div>
    </div>
  </section>

</main>
</Layout>

<style>
  .consultation-page {
    background: #F8FAFC;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Hero */
  .hero {
    background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
    color: white;
    padding: 48px 20px 44px;
    text-align: center;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 16px;
    font-weight: 700;
    color: #FFFFFF;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.35);
    line-height: 1.2;
  }

  .hero .subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 580px;
    margin: 0 auto 28px;
    line-height: 1.6;
  }

  .hero-cta {
    display: inline-block;
    background: #F59E0B;
    color: #0F172A;
    padding: 14px 32px;
    border-radius: 8px;
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }

  .hero-cta:hover {
    background: #D97706;
    transform: translateY(-1px);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .hero h1 { font-size: 1.8rem; }
  }

  /* Content layout */
  .content {
    padding: 52px 20px;
  }

  .two-column {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  @media (max-width: 768px) {
    .two-column { grid-template-columns: 1fr; }
  }

  /* Author card */
  .author-card {
    display: flex;
    gap: 20px;
    background: white;
    padding: 28px;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    margin-bottom: 24px;
    align-items: center;
  }

  .author-photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #F59E0B;
    flex-shrink: 0;
  }

  .author-info h3 {
    font-size: 1.25rem;
    margin-bottom: 4px;
    color: #0F172A;
  }

  .author-info p {
    color: #64748B;
    margin-bottom: 10px;
    font-size: 0.95rem;
  }

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #0077B5;
    text-decoration: none;
    font-size: 0.9rem;
  }

  .linkedin-link:hover { text-decoration: underline; }

  /* What you get */
  .what-you-get {
    background: white;
    padding: 28px;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .what-you-get h2 {
    font-size: 1.4rem;
    margin-bottom: 22px;
    color: #0F172A;
  }

  .what-you-get ul {
    list-style: none;
    padding: 0;
  }

  .what-you-get li {
    display: flex;
    gap: 14px;
    margin-bottom: 18px;
    align-items: flex-start;
  }

  .what-you-get .icon {
    font-size: 1.4rem;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .what-you-get strong {
    display: block;
    color: #0F172A;
    margin-bottom: 3px;
    font-size: 0.95rem;
  }

  .what-you-get p {
    color: #64748B;
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.5;
  }

  /* Booking card */
  .booking-card {
    background: white;
    padding: 28px;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
    border: 2px solid #F59E0B;
    margin-bottom: 24px;
    scroll-margin-top: 80px;
  }

  .price-tag {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 4px;
  }

  .price {
    font-size: 3.25rem;
    font-weight: 700;
    color: #0F172A;
    line-height: 1;
  }

  .duration {
    color: #64748B;
    font-size: 1.05rem;
  }

  .booking-card h2 {
    font-size: 1.3rem;
    color: #0F172A;
    margin-bottom: 18px;
    margin-top: 12px;
  }

  .outcomes {
    list-style: none;
    padding: 0;
    margin-bottom: 28px;
  }

  .outcomes li {
    padding: 9px 0;
    color: #334155;
    border-bottom: 1px solid #E2E8F0;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .outcomes li:last-child { border-bottom: none; }

  /* Primary CTA button */
  .cta-button {
    display: block;
    width: 100%;
    background: #F59E0B;
    color: #0F172A;
    padding: 20px 32px;
    border-radius: 10px;
    font-size: 1.2rem;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 4px 14px rgba(245, 158, 11, 0.35);
    letter-spacing: -0.01em;
  }

  .cta-button:hover {
    background: #D97706;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(245, 158, 11, 0.45);
    text-decoration: none;
  }

  .guarantee {
    text-align: center;
    margin-top: 16px;
    color: #64748B;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  /* Testimonial */
  .testimonial {
    background: #FEF3C7;
    padding: 28px;
    border-radius: 12px;
    border-left: 4px solid #F59E0B;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .quote-mark {
    font-size: 4rem;
    line-height: 1;
    color: #F59E0B;
    font-family: Georgia, serif;
    margin-bottom: -12px;
    display: block;
  }

  .quote-text {
    color: #1E293B;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 0 12px;
    font-style: italic;
  }

  .attribution {
    font-weight: 700;
    color: #475569;
    font-size: 0.95rem;
    margin: 0;
  }

  /* FAQ */
  .faq {
    background: white;
    padding: 52px 20px;
  }

  .faq h2 {
    text-align: center;
    font-size: 1.8rem;
    margin-bottom: 36px;
    color: #0F172A;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 860px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .faq-grid { grid-template-columns: 1fr; }
  }

  .faq-item {
    background: #F8FAFC;
    padding: 24px;
    border-radius: 10px;
    border: 1px solid #E2E8F0;
  }

  .faq-item h3 {
    font-size: 1rem;
    color: #0F172A;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .faq-item p {
    color: #64748B;
    line-height: 1.6;
    font-size: 0.95rem;
    margin: 0;
  }
</style>
