---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, author, tags, gradient } = Astro.props;

// Default gradient if none specified
const heroGradient = gradient || 'from-blue-900 via-blue-800 to-emerald-700';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		
		<!-- Hero Section with Gradient -->
		<section class="hero-section">
			<div class="hero-content">
				<div class="hero-meta">
					<time class="publish-date" datetime={pubDate.toISOString()}>
						<FormattedDate date={pubDate} />
					</time>
					{updatedDate && (
						<time class="updated-date" datetime={updatedDate.toISOString()}>
							Updated: <FormattedDate date={updatedDate} />
						</time>
					)}
				</div>
				
				<h1 class="hero-title">{title}</h1>
				
				<p class="hero-description">{description}</p>
				
				{tags && tags.length > 0 && (
					<div class="hero-tags">
						{tags.map((tag: string) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				)}
				
				{author && (
					<div class="hero-author">
						<span class="author-label">By</span>
						<span class="author-name">{author}</span>
					</div>
				)}
			</div>
		</section>

		<!-- Main Content -->
		<main class="article-main">
			<article class="article-content">
				<slot />
			</article>
			
			<!-- Author Bio -->
			{author && (
				<aside class="author-bio">
					<div class="author-bio-content">
						<div class="author-avatar">👨‍💼</div>
						<div class="author-details">
							<h3>About {author}</h3>
							<p>
								SEO strategist helping small business owners rank higher on Google without expensive agencies. 
								Connect for personalized SEO guidance.
							</p>
							<div class="author-links">
								<a href="https://www.linkedin.com/in/emil-mequita/" target="_blank" rel="noopener" class="author-link">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
									Connect on LinkedIn
								</a>
								<a href="/consultation" class="author-link">
									Book a Strategy Session
								</a>
							</div>
						</div>
					</div>
				</aside>
			)}
			
			<!-- Article Footer / CTA -->
			<aside class="article-cta">
				<div class="cta-box">
					<h3>📥 Free SEO Checklist</h3>
					<p>Get our comprehensive DIY SEO checklist. Everything you need to optimize your website, step-by-step.</p>
					<a href="#" class="btn btn-primary">Download Free Checklist</a>
				</div>
			</aside>
		</main>

		<Footer />
	</body>
</html>

<style define:vars={{ heroGradient }}>
	/* Hero Section with Gradient Background */
	.hero-section {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 50%, var(--color-accent-dark) 100%);
		background: linear-gradient(135deg, #0F172A 0%, #1E293B 50%, #D97706 100%);
		padding: var(--space-16) var(--space-4) var(--space-20);
		text-align: center;
		position: relative;
		overflow: hidden;
	}
	
	/* Subtle pattern overlay for texture */
	.hero-section::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image: 
			radial-gradient(circle at 25% 25%, rgba(255, 255, 255, 0.05) 0%, transparent 50%),
			radial-gradient(circle at 75% 75%, rgba(255, 255, 255, 0.03) 0%, transparent 50%);
		pointer-events: none;
	}
	
	.hero-content {
		max-width: var(--content-width);
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}
	
	.hero-meta {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-4);
		margin-bottom: var(--space-6);
		font-size: var(--font-size-sm);
		color: var(--color-accent-light);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	
	.publish-date {
		color: var(--color-accent-light);
	}
	
	.updated-date {
		color: var(--color-gray-400);
		padding-left: var(--space-4);
		border-left: 1px solid var(--color-gray-600);
	}
	
	.hero-title {
		font-size: var(--font-size-5xl);
		font-weight: var(--font-weight-bold);
		line-height: var(--line-height-tight);
		color: var(--color-white);
		margin-bottom: var(--space-6);
		letter-spacing: -0.03em;
		text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
	}
	
	.hero-description {
		font-size: var(--font-size-xl);
		line-height: var(--line-height-relaxed);
		color: var(--color-gray-200);
		max-width: 600px;
		margin: 0 auto var(--space-8);
	}
	
	.hero-tags {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-3);
		margin-bottom: var(--space-6);
	}
	
	.tag {
		display: inline-block;
		padding: var(--space-2) var(--space-4);
		background-color: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(10px);
		color: var(--color-white);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-medium);
		border-radius: var(--radius-full);
		border: 1px solid rgba(255, 255, 255, 0.2);
	}
	
	.hero-author {
		font-size: var(--font-size-base);
		color: var(--color-gray-300);
	}
	
	.author-label {
		color: var(--color-gray-400);
		margin-right: var(--space-2);
	}
	
	.author-name {
		color: var(--color-white);
		font-weight: var(--font-weight-semibold);
	}
	
	/* Main Content Area */
	.article-main {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: var(--space-12) var(--space-4);
	}
	
	.article-content {
		background-color: var(--color-white);
		padding: var(--space-8) var(--space-6);
		margin-bottom: var(--space-12);
	}
	
	/* Improve prose spacing and readability */
	.article-content :global(h2) {
		scroll-margin-top: var(--space-20);
		padding-top: var(--space-4);
		border-bottom: 2px solid var(--color-gray-200);
		padding-bottom: var(--space-4);
	}
	
	.article-content :global(h3) {
		scroll-margin-top: var(--space-20);
		color: var(--color-gray-800);
	}
	
	.article-content :global(h4) {
		scroll-margin-top: var(--space-20);
		color: var(--color-gray-700);
	}
	
	/* Improve list styling */
	.article-content :global(ul) {
		list-style-type: none;
		padding-left: 0;
	}
	
	.article-content :global(ul li) {
		padding-left: var(--space-8);
		position: relative;
		margin-bottom: var(--space-4);
	}
	
	.article-content :global(ul li::before) {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--color-accent);
		font-weight: var(--font-weight-bold);
		font-size: var(--font-size-lg);
	}
	
	.article-content :global(ol) {
		counter-reset: item;
		list-style-type: none;
		padding-left: 0;
	}
	
	.article-content :global(ol li) {
		counter-increment: item;
		padding-left: var(--space-10);
		position: relative;
		margin-bottom: var(--space-4);
	}
	
	.article-content :global(ol li::before) {
		content: counter(item);
		position: absolute;
		left: 0;
		top: 0;
		background-color: var(--color-accent);
		color: var(--color-white);
		font-weight: var(--font-weight-bold);
		font-size: var(--font-size-sm);
		width: var(--space-8);
		height: var(--space-8);
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-full);
	}
	
	/* Enhance tables */
	.article-content :global(table) {
		box-shadow: var(--shadow-md);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}
	
	/* Enhance blockquotes */
	.article-content :global(blockquote) {
		background-color: var(--color-gray-50);
		border-left: 4px solid var(--color-accent);
		padding: var(--space-6);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-sm);
	}
	
	/* Enhance code blocks */
	.article-content :global(pre) {
		position: relative;
	}
	
	/* Author Bio */
	.author-bio {
		margin-top: var(--space-12);
		margin-bottom: var(--space-8);
	}
	
	.author-bio-content {
		display: flex;
		gap: var(--space-6);
		padding: var(--space-8);
		background-color: var(--color-gray-50);
		border-radius: var(--radius-xl);
		border: 2px solid var(--color-gray-200);
	}
	
	.author-avatar {
		font-size: 60px;
		flex-shrink: 0;
	}
	
	.author-details h3 {
		font-size: var(--font-size-xl);
		color: var(--color-primary);
		margin-bottom: var(--space-3);
	}
	
	.author-details p {
		color: var(--color-gray-700);
		line-height: var(--line-height-relaxed);
		margin-bottom: var(--space-4);
	}
	
	.author-links {
		display: flex;
		gap: var(--space-4);
		flex-wrap: wrap;
	}
	
	.author-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-2) var(--space-4);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-semibold);
		color: var(--color-accent-dark);
		text-decoration: none;
		border-radius: var(--radius-md);
		transition: all 0.2s ease;
	}
	
	.author-link:hover {
		color: var(--color-accent);
		background-color: var(--color-white);
		text-decoration: none;
	}
	
	.author-link svg {
		flex-shrink: 0;
	}
	
	/* CTA Box */
	.article-cta {
		margin-top: var(--space-12);
	}
	
	.cta-box {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
		padding: var(--space-10) var(--space-8);
		border-radius: var(--radius-xl);
		text-align: center;
		box-shadow: var(--shadow-2xl);
		position: relative;
		overflow: hidden;
	}
	
	.cta-box::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image: 
			radial-gradient(circle at 20% 50%, rgba(245, 158, 11, 0.1) 0%, transparent 50%),
			radial-gradient(circle at 80% 50%, rgba(245, 158, 11, 0.05) 0%, transparent 50%);
		pointer-events: none;
	}
	
	.cta-box > * {
		position: relative;
		z-index: 1;
	}
	
	.cta-box h3 {
		color: var(--color-white);
		font-size: var(--font-size-3xl);
		margin-bottom: var(--space-4);
	}
	
	.cta-box p {
		color: var(--color-gray-200);
		font-size: var(--font-size-lg);
		margin-bottom: var(--space-6);
		max-width: 100%;
	}
	
	.cta-box .btn {
		background-color: var(--color-accent);
		color: var(--color-white);
		font-size: var(--font-size-lg);
		padding: var(--space-4) var(--space-10);
		border-radius: var(--radius-lg);
		font-weight: var(--font-weight-bold);
		text-decoration: none;
		display: inline-block;
		transition: all 0.2s ease;
		box-shadow: var(--shadow-lg);
	}
	
	.cta-box .btn:hover {
		background-color: var(--color-accent-light);
		transform: translateY(-2px);
		box-shadow: var(--shadow-xl);
		text-decoration: none;
	}
	
	/* Responsive Design */
	@media (max-width: 768px) {
		.hero-section {
			padding: var(--space-12) var(--space-4) var(--space-16);
		}
		
		.hero-title {
			font-size: var(--font-size-4xl);
		}
		
		.hero-description {
			font-size: var(--font-size-lg);
		}
		
		.hero-meta {
			flex-direction: column;
			gap: var(--space-2);
		}
		
		.updated-date {
			border-left: none;
			padding-left: 0;
		}
		
		.article-main {
			padding: var(--space-8) var(--space-4);
		}
		
		.article-content {
			padding: var(--space-6) var(--space-4);
		}
		
		.cta-box {
			padding: var(--space-8) var(--space-6);
		}
		
		.cta-box h3 {
			font-size: var(--font-size-2xl);
		}
		
		.author-bio-content {
			flex-direction: column;
			text-align: center;
			align-items: center;
		}
		
		.author-links {
			justify-content: center;
		}
	}
	
	@media (max-width: 480px) {
		.hero-title {
			font-size: var(--font-size-3xl);
		}
		
		.cta-box .btn {
			width: 100%;
		}
	}
</style>
